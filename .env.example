# ============================================================
# harosystem 環境変数テンプレート
#
# このファイルを .env にコピーして値を変更してください:
#   cp .env.example .env
#
# .env は .gitignore 済みのためリポジトリにはコミットされません。
# 公開サーバーで運用する場合は必ず強力なパスワードに変更すること。
# ============================================================

# PostgreSQL の認証情報
POSTGRES_USER=harosystem
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=harosystem

# JWT 署名鍵 (必ず推測不可能な長いランダム文字列に変更すること)
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# ── 外部アクセス対応 (任意) ──
# このマシン以外 (LAN の別端末やドメイン) からアクセスする場合に設定する。
# 未設定なら localhost のみで動作する (従来どおり)。

# CORS 許可オリジン (カンマ区切り)。ng serve や別オリジンの SPA から API を叩く場合に。
# 例: CORS_ORIGINS=http://localhost:4200,https://calendar.example.com
# CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# 自己署名証明書の SAN に追加するホスト名/IP (カンマ区切り)。
# このサーバーのホスト名やLAN IPを入れると、その宛先でアクセスしても
# 証明書のホスト名不一致が出ない (自己署名の警告自体は残る)。
# 変更後は証明書を作り直すため frontend を再作成する: docker compose up -d --build --force-recreate frontend
# 例: CERT_HOSTS=192.168.1.10,calendar.local
# CERT_HOSTS=
